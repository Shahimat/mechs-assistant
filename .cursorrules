{
  "project": {
    "name": "mechs-assistant",
    "description": "WEB ассистент игры Мехи.Земля"
  },
  "rules": {
    "language": "ru_RU",
    "communication": "ВСЕГДА общайся на русском языке. Все комментарии в коде должны быть на русском.",
    
    "stack": {
      "frontend": "React 18+ с функциональными компонентами",
      "ui_framework": "Material-UI (MUI) v5+ с Emotion",
      "state": "Zustand для глобального состояния",
      "data": "TanStack Query (React Query) для асинхронных данных",
      "typescript": "Строгий режим TypeScript (strict: true)",
      "testing": "Jest + React Testing Library",
      "bundler": "Rspack",
      "styling_method": "Styled Components с MUI + CSS-in-JS"
    },
    
    "mui": {
      "version": "v5+ (MUI Core)",
      "styling": "Используй Emotion (styled-components синтаксис)",
      "theming": "Обязательно используй ThemeProvider",
      "components": "Используй компоненты MUI как строительные блоки",
      "customization": "Кастомизируй через styled() или sx prop",
      "icons": "Используй @mui/icons-material",
      "lab_components": "Избегай @mui/lab для продакшена"
    },
    
    "typescript": {
      "strict": true,
      "config": {
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true
      },
      "mui_types": "Используй правильные типы для MUI компонентов",
      "rules": "НИКОГДА не используй 'any'. Для MUI props используй ComponentProps."
    },
    
    "react": {
      "components": "Функциональные компоненты с TypeScript",
      "mui_integration": "Обертывай MUI компоненты в кастомные с дополнительной логикой",
      "performance": "Для MUI списков используй виртуализацию (react-window)"
    },
    
    "zustand": {
      "pattern": "Используй паттерн слайсов (slices)",
      "middleware": "Добавляй devtools middleware в разработке",
      "persist": "Для MUI темы используй persist middleware"
    },
    
    "tanstack_query": {
      "version": "v5+",
      "query_keys": "Используй Query Key Factory паттерн",
      "mui_integration": "Используй MUI скелетоны для состояния загрузки"
    },
    
    "testing": {
      "framework": "Jest + React Testing Library",
      "mui_testing": "Используй screen из @testing-library/react",
      "theme_provider": "Оберни тесты в ThemeProvider",
      "coverage": "Стремись к покрытию >80%"
    },
    
    "rspack": {
      "config": "Конфигурация в rspack.config.js",
      "mui_optimization": "Убедись, что tree-shaking работает для MUI"
    },
    
    "code_style": {
      "indentation": 2,
      "quotes": "single",
      "semicolons": true,
      "trailing_commas": "es5",
      "max_line_length": 100,
      "mui_imports": "Импортируй MUI компоненты деструктуризацией"
    }
  }
}