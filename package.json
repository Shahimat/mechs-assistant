{
  "name": "mechs-assistant",
  "version": "0.0.1",
  "description": "Ассистент игры Мехи.Земля — монорепо (SPA + COP)",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": {
    "name": "Gevorg Nakhapetyan",
    "email": "ngs22071993@gmail.com",
    "url": "https://github.com/Shahimat"
  },
  "license": "ISC",
  "scripts": {
    "build:data": "tsx scripts/build-data/index.ts",
    "dev": "npm run build:data && npm run dev -w @mechs/web",
    "build": "npm run build:data && npm run build -w @mechs/web",
    "test": "npm run build:data && npm run test -w @mechs/web",
    "test:watch": "npm run build:data && npm run test:watch -w @mechs/web",
    "test:coverage": "npm run build:data && npm run test:coverage -w @mechs/web",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "sync:sheets": "tsx scripts/parser-google-sheets/index.ts",
    "setup:sheets": "tsx scripts/setup-sheets-columns/index.ts",
    "setup:todo": "tsx scripts/setup-todo-sheet/index.ts",
    "sync:wiki": "tsx scripts/parser-wiki/index.ts",
    "convert:webp": "tsx scripts/convert-to-webp/index.ts",
    "build:phash": "node apps/cop/scripts/build-phash-index.mjs"
  },
  "overrides": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "googleapis": "^173.0.0",
    "js-yaml": "^5.2.0",
    "prettier": "^3.3.3",
    "sharp": "^0.35.2",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0"
  }
}
