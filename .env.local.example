# Шаблон локальных переменных окружения. Скопируй в .env.local и заполни.
# .env.local — в .gitignore, коммитить не нужно.
#
# Служит для локальных запусков `npm run sync:sheets` (и других).
# В CI (GitHub Actions) те же ключи задаются через secrets в workflow.

# Абсолютный путь к JSON-ключу Service Account.
# См. docs/manuals/setup-google-sheets.md, шаг 6.
GSHEETS_SA_KEY_PATH=/Users/<you>/.config/mechs-assistant/gsheets-sa.json

# ID Google-таблицы с overlay (кусок URL между /d/ и /edit).
# См. docs/manuals/setup-google-sheets.md, шаг 6.
# Помимо server-скриптов (setup:sheets, sync:sheets) — также инжектируется
# в клиентский бандл через rspack DefinePlugin: используется в
# src/config/links.ts для сборки URL публичных листов (сейчас — только
# лист `todo`, страница /todo). Не секрет: доступ к таблице
# контролируется Sheets sharing, ID виден в клиенте.
MECHS_OVERLAY_SPREADSHEET_ID=<paste-your-google-sheet-id-here>
